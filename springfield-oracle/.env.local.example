# Beehiiv Newsletter Configuration
#
# To use the exit intent popup subscription feature:
#   1. Get your API credentials from Beehiiv:
#      - Log in to beehiiv.com
#      - Go to Settings → API
#      - Generate an API key (copy the full token)
#      - Find your Publication ID in the Publication Settings
#   2. Copy this file: cp .env.local.example .env.local
#   3. Fill in your actual credentials below
#   4. Never commit .env.local to git (it's in .gitignore)

# Beehiiv API Key (starts with "pak_")
# Get from: https://dashboard.beehiiv.com/settings/api
BEEHIIV_API_KEY=pak_your_api_key_here

# Beehiiv Publication ID (UUID format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# Get from: https://dashboard.beehiiv.com/publication/settings
BEEHIIV_PUBLICATION_ID=your-publication-id-here
