{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "springfieldoracle.com" }],
      "headers": { "Location": "https://www.springfieldoracle.com/$1" },
      "status": 301
    },
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "springfield-oracle.vercel.app" }],
      "headers": { "Location": "https://www.springfieldoracle.com/$1" },
      "status": 301
    },
    { "src": "/api/subscribe", "dest": "/api/subscribe.js" },
    { "src": "/api/og-image(.*)", "dest": "/api/og-image.js" },
    { "src": "/api/news(.*)", "dest": "/api/news.js" },
    { "src": "/share(.*)", "dest": "/api/share.js" },
    { "src": "/prediction/([^/]+)", "dest": "/api/share.js?id=$1" },
    { "src": "/_vercel/(.*)", "dest": "/_vercel/$1" },
    { "src": "/about", "dest": "/public/about.html" },
    { "src": "/faq", "dest": "/public/faq.html" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/sitemap-home.xml", "dest": "/public/sitemap-home.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/sitemap-about.xml", "dest": "/public/sitemap-about.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/sitemap-faq.xml", "dest": "/public/sitemap-faq.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/sitemap-predictions.xml", "dest": "/public/sitemap-predictions.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/simpsons-([^/]+)", "dest": "/public/simpsons-$1.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/:path*.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://connect.facebook.net https://www.google-analytics.com https://ssl.google-analytics.com https://subscribe-forms.beehiiv.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.facebook.com https://springfieldoracle.com https://www.springfieldoracle.com; connect-src 'self' https://api.rss2json.com https://corsproxy.io https://api.allorigins.win https://formspree.io https://app.beehiiv.com https://www.google-analytics.com https://analytics.google.com https://stats.g.doubleclick.net; frame-src https://www.googletagmanager.com https://subscribe-forms.beehiiv.com; frame-ancestors 'none';"
        }
      ]
    }
  ]
}
