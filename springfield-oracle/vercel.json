{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/_vercel/(.*)", "dest": "/_vercel/$1" },
    { "src": "/about", "dest": "/public/about.html" },
    { "src": "/faq", "dest": "/public/faq.html" },
    { "src": "/sitemap.xml", "dest": "/public/sitemap.xml", "headers": { "Content-Type": "application/xml; charset=utf-8" } },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
